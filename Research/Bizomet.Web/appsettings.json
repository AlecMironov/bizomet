{
	"Serilog": {
		"MinimumLevel": {
			"Default": "Information",
			"Override": {
				"Microsoft": "Warning",
				"Microsoft.Hosting.Lifetime": "Information"
			}
		},
		"Filter": [
			{
				"Name": "ByExcluding",
				"Args": {
					"expression": "@mt = 'An unhandled exception has occurred while executing the request.'"
				}
			}
		],
		"WriteTo": [
			{
				"Name": "File",
				"Args": {
					"path": "./logs/log-.txt",
					"rollingInterval": "Day"
				}
			}
		]
	},
	"ConnectionStrings": {
		"BizometConnection": "Server=ALEC-SURFACE\\SQLEXPRESS;Database=Bizomet.Data;Integrated Security=true;MultipleActiveResultSets=true;"
	},
	"IdentityServer": {
		"Clients": {
			"Bizomet.Web": {
				"Profile": "IdentityServerSPA"
			}
		}
	},
	"AllowedHosts": "*"
}
